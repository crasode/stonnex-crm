# ------------------------------------------------------------
# Stonnex CRM — environment variables
# Copy to .env (local) or set in Vercel dashboard (production)
# ------------------------------------------------------------

# --- Database ---
# Local dev (SQLite) or prod (Neon/Postgres). Prisma reads this.
# Local example:    DATABASE_URL="file:./prisma/dev.db"
# Neon example:     DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="file:./prisma/dev.db"

# --- NextAuth ---
# Generate via:   openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Admin login (single user for v1) ---
# Email + bcrypt hash (10 rounds). Generate hash with:
#   node -e "console.log(require('bcryptjs').hashSync('yourPassword',10))"
ADMIN_EMAIL="calvin@stonnex.com"
ADMIN_PASSWORD_HASH="$2a$10$replace-me-with-bcrypt-hash"

# --- Incoming webhook secret (Make.com → us) ---
# Make sends this as ?secret=... on the webhook URL
WEBHOOK_SECRET="replace-me-random-long-string"

# --- Google Sheets backfill (one-time import) ---
# Service account JSON (base64-encoded single line), and sheet ID.
# Create service account at https://console.cloud.google.com/ → enable Sheets API.
# Share the sheet with the service account email.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=""
SHEET_ID="1Mlu3mSEYfPtLHoPF1PKo8Km0-OkM2r7YofFCHqL29dc"
SHEET_TAB="Master Lead CRM"
