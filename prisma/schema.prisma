generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  zip        String?

  service    String?
  message    String?
  source     String?  @default("website")
  status     String   @default("new")
  notes      String?
  assignedTo String?
}
